{
  "rewrites": [
    {
      "source": "/api/tableau/:path*",
      "destination": "https://public.tableau.com/:path*"
    },
    {
      "source": "/api/powerbi/:path*",
      "destination": "https://community.fabric.microsoft.com/:path*"
    },
    {
      "source": "/api/novypro/:path*",
      "destination": "https://www.novypro.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(ico|png|svg))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
